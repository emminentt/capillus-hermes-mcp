# Path to the Capillus monitor data directory.
# Defaults to ~/.capillus-home-monitor/data when unset.
CAPILLUS_MONITOR_DATA_DIR=/Users/you/.capillus-home-monitor/data

# Optional. Used for daily adherence boundaries.
CAPILLUS_TIME_ZONE=America/New_York

# Optional. Override if sqlite3 is not on PATH.
SQLITE3_BIN=sqlite3
